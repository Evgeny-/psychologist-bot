# API keys
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Telegram IDs
TELEGRAM_CHANNEL_ID=
TELEGRAM_DISCUSSION_GROUP_ID=
# Your Telegram user ID (get from @userinfobot)
TELEGRAM_OWNER_USER_ID=
# Optional: admin chat ID for error notifications
TELEGRAM_ADMIN_CHAT_ID=

# Provider selection
ASR_PROVIDER=elevenlabs        # or "openai"
LLM_PROVIDER=claude            # or "openai"

# Models
OPENAI_ASR_MODEL=gpt-4o-transcribe
OPENAI_LLM_MODEL=gpt-5.4
CLAUDE_LLM_MODEL=claude-sonnet-4-6
ELEVENLABS_ASR_MODEL=scribe_v2

# Compare mode — run all LLM providers in parallel
COMPARE_MODE=false

# Language
BOT_LANGUAGE=ru                # "ru" or "en"

# Timezone for date calculations (IANA format)
BOT_TIMEZONE=Europe/Amsterdam